{
  "name": "@zulip/github-actions-zulip",
  "version": "1.0.1",
  "private": true,
  "description": "Zulip GitHub Actions",
  "type": "module",
  "scripts": {
    "lint": "eslint --ext=.ts . && prettier --check --log-level=warn . \"!**/*.{js,ts}\"",
    "lint:fix": "eslint --ext=.ts --fix . && prettier --check --write --log-level=warn . \"!**/*.{js,ts}\"",
    "package": "ncc build src/send-message.ts -o dist/send-message",
    "test": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zulip/github-actions-zulip.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "Zulip"
  ],
  "author": "Yuzu tech (https://www.yuzutech.fr)",
  "contributors": [
    "Guillaume Grossetie <ggrossetie@yuzutech.fr>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zulip/github-actions-zulip/issues"
  },
  "homepage": "https://github.com/zulip/github-actions-zulip#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "ts-async-results": "^0.7.10",
    "ts-results": "^3.3.0",
    "zulip-js": "^2.0.9"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-xo": "^0.51.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3"
  }
}
